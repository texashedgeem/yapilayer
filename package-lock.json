{
  "name": "yapilayer-workspace",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "yapilayer-workspace",
      "license": "Apache-2.0",
      "workspaces": [
        "demo/ais-demo",
        "demo/pis-demo",
        "sdk/typescript"
      ]
    },
    "demo/ais-demo": {
      "name": "@yapilayer/ais-demo",
      "version": "0.1.0",
      "license": "Apache-2.0"
    },
    "demo/pis-demo": {
      "name": "@yapilayer/pis-demo",
      "version": "0.1.0",
      "license": "Apache-2.0"
    },
    "node_modules/@yapilayer/ais-demo": {
      "resolved": "demo/ais-demo",
      "link": true
    },
    "node_modules/@yapilayer/pis-demo": {
      "resolved": "demo/pis-demo",
      "link": true
    },
    "node_modules/@yapilayer/sdk": {
      "resolved": "sdk/typescript",
      "link": true
    },
    "sdk/typescript": {
      "name": "@yapilayer/sdk",
      "version": "0.1.0",
      "license": "Apache-2.0"
    }
  }
}
